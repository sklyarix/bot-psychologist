generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiGoals          AiGoal[]
  AiQuestionAnswer AiQuestionAnswer[]
  webVisits        WebVisit[]
}

model Job {
  id        String    @id @default(uuid())
  name      String
  status    JobStatus @default(queued)
  errorLog  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  aiGoal           AiGoal             @relation(fields: [aiGoalId], references: [id])
  aiGoalId         String             @unique
  AiQuestionAnswer AiQuestionAnswer[]
}

enum JobStatus {
  queued
  active
  completed
  failed
}

model AiGoal {
  id          String    @id @default(uuid())
  title       String
  description Json?
  status      JobStatus @default(queued)
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  User   User?   @relation(fields: [userId], references: [id])
  userId String?

  Job Job?

  @@map("Ai_Goal")
}

model AiQuestionAnswer {
  id       String    @id @default(uuid())
  question String
  answer   String?
  status   JobStatus @default(queued)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User   User?   @relation(fields: [userId], references: [id])
  userId String?

  Job   Job?    @relation(fields: [jobId], references: [id])
  jobId String?

  @@map("Ai_Question_Answer")
}

/// Web visits from users to the webapp
model WebVisit {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  visitedAt DateTime @default(now())

  @@index([visitedAt])
  @@index([userId, visitedAt])
  @@map("web_visit")
}

/// Content pages for editable site content (HTML stored as text)
model Page {
  id    String @id @default(uuid())
  slug  String @unique
  title String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields          PageField[]
  pageFieldGroups PageFieldGroup[]

  @@map("pages")
}

/// Optional grouping of fields within a page (for sections or logical groups)
model PageFieldGroup {
  id        String   @id @default(uuid())
  page      Page     @relation(fields: [pageId], references: [id])
  pageId    String
  name      String // идентификатор группы, например "hero_section", "about_section"
  title     String? // отображаемый заголовок группы
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields PageField[]

  @@index([pageId])
  @@map("page_field_groups")
}

model PageField {
  id           String          @id @default(uuid())
  page         Page            @relation(fields: [pageId], references: [id])
  pageId       String
  pageGroup    PageFieldGroup? @relation(fields: [pageGroupId], references: [id])
  pageGroupId  String?
  name         String // field identifier, e.g. "hero_text", "about_body"
  title        String // отображаемый заголовок в админке
  html         String // HTML content
  displayOrder Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([pageId])
  @@index([pageGroupId])
  @@map("page_fields")
}

/// Bot commands content storage
model BotCommand {
  id        String   @id @default(uuid())
  command   String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bot_commands")
}

/// AI Goal notification messages
model AiGoalMessage {
  id        String   @id @default(uuid())
  day       Int      @unique
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_goal_messages")
}
